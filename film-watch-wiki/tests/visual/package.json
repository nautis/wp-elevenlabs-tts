{
  "name": "film-watch-wiki-visual-tests",
  "version": "1.0.0",
  "description": "Visual and layout tests for Film Watch Wiki using Puppeteer",
  "main": "index.js",
  "scripts": {
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ],
    "testTimeout": 60000
  },
  "keywords": [
    "puppeteer",
    "testing",
    "wordpress"
  ],
  "author": "",
  "license": "GPL-2.0",
  "dependencies": {
    "jest": "^29.7.0",
    "puppeteer": "^21.6.0"
  }
}
